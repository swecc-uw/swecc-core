# ======================================================================# SWECC Backend - Local Development Environment Variables
# ======================================================================# Copy this file to .env and fill in the SENSITIVE values from production
# ======================================================================
# ======================================================================# Database (PostgreSQL)
# ======================================================================DB_HOST=swecc-db-instance
DB_NAME=swecc
DB_PORT=5432
DB_USER=swecc
DB_PASSWORD=swecc_dev_password

# ======================================================================# Redis
# ======================================================================REDIS_HOST=swecc-redis-instance
REDIS_PORT=6379

# ======================================================================# RabbitMQ
# ======================================================================RABBITMQ_USER=guest
RABBITMQ_PASS=guest
RABBIT_HOST=swecc-rabbitmq-instance
RABBIT_PORT=5672
RABBIT_VHOST=/
SERVER_RABBIT_USER=guest
SERVER_RABBIT_PASS=guest
BOT_RABBIT_USER=guest
BOT_RABBIT_PASS=guest

# ======================================================================# Django Server
# ======================================================================DJANGO_DEBUG=true
METRIC_SERVER_URL=http://swecc-chronos:8002

# JWT for session/auth (SENSITIVE - replace with prod value)
JWT_SECRET=dev_jwt_secret_change_in_production

# ======================================================================# External Services - SENSITIVE (get from prod)
# ======================================================================SENDGRID_API_KEY=SG.placeholder
SUPABASE_URL=https://placeholder.supabase.co
SUPABASE_KEY=placeholder_key
AWS_ACCESS_KEY_ID=placeholder
AWS_SECRET_ACCESS_KEY=placeholder
AWS_BUCKET_NAME=swecc-dev-bucket
AWS_DEFAULT_REGION=us-west-2
GEMINI_API_KEY=placeholder

# ======================================================================# Discord Bot - SENSITIVE (get from prod or use test bot)
# ======================================================================DISCORD_TOKEN=placeholder
SWECC_SERVER=000000000000000000
SWECC_API_KEY=placeholder

# Discord Channel IDs (use placeholder IDs - replace with real ones for bot testing)
ADMIN_CHANNEL=000000000000000000
READING_GROUP_CHANNEL=000000000000000000
LC_CHANNEL_ID=000000000000000000
TRANSCRIPTS_CHANNEL=000000000000000000
SWECC_RESUME_CHANNEL=000000000000000000
INTERNSHIP_CHANNEL_ID=000000000000000000
NEW_GRAD_CHANNEL_ID=000000000000000000
OFF_TOPIC_CHANNEL_ID=000000000000000000
TIMELINE_CHANNEL=000000000000000000

# Discord Role IDs
OFFICER_ROLE_ID=000000000000000000
VERIFIED_ROLE_ID=000000000000000000
VERIFIED_EMAIL_ROLE_ID=000000000000000000
COHORT_CATEGORY_ID=000000000000000000

# Bot misc
PREFIX_COMMAND=!
CALENDAR_URL=https://calendar.google.com/placeholder

# Advent of Code
AOC_LEADERBOARD_ID=0
AOC_SESSION=placeholder
AOC_LEADERBOARD_KEY=placeholder

# ======================================================================# Bench (BenchAnything backend) - SENSITIVE keys for model providers
# ======================================================================ANTHROPIC_API_KEY=
OPENAI_API_KEY=
# GOOGLE_API_KEY is what LiteLLM (used by bench-api) reads for gemini/* models.
# It falls back to GEMINI_API_KEY (set above for the AI service) at the compose
# layer, so leaving this empty is fine if GEMINI_API_KEY is set — the same
# Google AI Studio key works for both. Do not set this to "placeholder" while
# GEMINI_API_KEY holds your real key; bench-api will skip placeholder values.
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# Bench shares the swecc Postgres database — the bench schema is a Django app
# at services/server/server/bench/. swecc-server runs `migrate` on startup (compose + prod).
# Model changes must ship committed files under bench/migrations/ (CI enforces this).
# Bench API public URL (Swagger/OpenAPI paths). Required when the UI hits bench via
# nginx at http://localhost/bench/ (docker compose --profile with-nginx).
# Leave unset in compose to use the default /bench; set empty only for direct :8010 access.
ORCH_GATEWAY_PREFIX=/bench
# ORCH_PUBLIC_BASE_URL=https://api.example.com/bench

# Host port to expose bench-api on (avoids clashing with Django on 8000)
BENCH_API_PORT=8010

# Bench auth (production). Local dev can set BENCH_AUTH_DISABLED=1 on bench-api.
# CORS for Mesocosm SPA + local Vite (bench-api; required with allow_credentials).
# Production bench-api_env (swecc-infra sync-configs) should include mesocosm.
# BENCH_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://mesocosm.swecc.org
# Guest demo allowlist: comma-separated domain IDs; leave empty to allow all domains.
# ORCH_DEMO_DOMAIN_IDS=
# Shared secret for EC2 worker job polling (set same value on bench-api and bench-worker).
# BENCH_WORKER_TOKEN=

# Bench worker poll interval (seconds)
WORKER_POLL_INTERVAL=10

# =============================================================================
# Scheduler (optional for local dev)
# =============================================================================
DOCKER_NETWORK=swecc-network
SCHEDULER_CONTAINER_NAME=swecc-scheduler
SCHEDULER_LOG_DIR=/app/logs
SCHEDULER_TEMP_DIR=/app/tmp
SCHEDULER_BASE_URL=http://swecc-server:8000
SCHEDULER_REQUEST_TIMEOUT=30
SCHEDULER_MAX_RETRIES=3
SCHEDULER_RETRY_DELAY=5
SCHEDULER_API_KEY=placeholder
