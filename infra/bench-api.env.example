# Swarm Docker config template: bench-api_env
# Copy keys into swecc-infra sync (prod bench-api_env) — do not commit real secrets.
#
# Public API base: https://api.swecc.org/bench
# Gateway strips /bench before forwarding; bench-api image sets ROOT_PATH=/bench.

# ── Required (same Postgres as swecc-server) ───────────────────────────────
DB_HOST=
DB_NAME=
DB_PORT=5432
DB_USER=
DB_PASSWORD=

# ── bench-api (prod) ───────────────────────────────────────────────────────
# Baked into the image; only set here if you need to override the Dockerfile default.
ROOT_PATH=/bench
ORCH_TRACE_DIR=/data/traces
ORCH_SANDBOX_URL=http://swecc_stack_bench-sandbox:8001

# ── Model providers (SENSITIVE — required for eval / test episode) ─────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=

# ── Optional ───────────────────────────────────────────────────────────────
# WORKER_API_URL is for bench-worker, not bench-api.
