# Developer / CI env for swecc-mesocosm CLI (not a Swarm service).
# Set in your shell or ~/.config/mesocosm.env — not deployed to prod servers.
#
# Defaults (no env file needed):
#   Remote:  https://api.swecc.org/bench  (+ https://api.swecc.org for auth)
#   Local:   MESOCOSM_LOCAL=1 → bench-api :8010, server :8000, adapter :8765
#
# Mesocosm SPA (mesocosm.swecc.org) uses https://api.swecc.org/bench as the API base
# (no trailing slash). API paths are /v1/... → .../bench/v1/... . Do not add trailing
# slashes to resource paths (/bench/v1/domains/ redirects incorrectly before fix).

# Optional overrides (production)
# MESOCOSM_BASE_URL=https://api.swecc.org/bench
# SWECC_SERVER_URL=https://api.swecc.org
# SWECC_BENCH_URL=https://api.swecc.org/bench

# Local full stack (docker compose + python adapter.py)
# MESOCOSM_LOCAL=1
# MESOCOSM_BASE_URL=http://127.0.0.1:8010
# SWECC_SERVER_URL=http://127.0.0.1:8000
# MESOCOSM_ENV_URL=http://127.0.0.1:8765

# Optional
# MESOCOSM_REQUEST_TIMEOUT_S=120
